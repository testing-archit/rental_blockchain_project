generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id              Int      @id @default(autoincrement())
  onchainId       Int      @unique
  landlord        String
  tenant          String
  rentAmount      String
  securityDeposit String
  startDate       Int
  endDate         Int
  bookingType     Int
  status          Int
  txHash          String?  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
